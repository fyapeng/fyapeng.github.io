---
import type { Locale } from "../data/profile";
import type { Paper } from "../data/papers";

interface Props {
  paper: Paper;
  lang?: Locale;
}

const { paper, lang = "zh" } = Astro.props;
const separator = lang === "zh" ? "、" : ", ";
const abstractLabel = lang === "zh" ? "摘要" : "Abstract";
const citationSuffix = lang === "zh" ? "。" : ".";
const links = paper.links?.[lang] ?? [];
const titleUrl = links[0]?.url;
const abstractText = paper.abstract?.[lang];
const abstractId = `abstract-${lang}-${paper.title.en
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/^-|-$/g, "")}`;
const citationMeta = [
  paper.date?.[lang] ?? (paper.year ? String(paper.year) : ""),
  paper.journal?.[lang] ?? paper.status?.[lang] ?? ""
].filter(Boolean);
---

<article class="publication">
  <p class="publication__citation">
    {
      paper.authors[lang].map((author, index) => (
        <span>
          {author.url ? (
            <a class:list={{ "is-me": author.me }} href={author.url} target="_blank" rel="noopener noreferrer">
              {author.name}
            </a>
          ) : (
            <span class:list={{ "is-me": author.me }}>{author.name}</span>
          )}
          {author.corresponding && <sup>*</sup>}
          {index < paper.authors[lang].length - 1 && <span>{separator}</span>}
        </span>
      ))
    }
    <span>{lang === "zh" ? "：" : ". "}</span>
    {
      titleUrl ? (
        <a class="publication__title" href={titleUrl} target="_blank" rel="noopener noreferrer">
          {paper.title[lang]}
        </a>
      ) : (
        <span class="publication__title">{paper.title[lang]}</span>
      )
    }
    {
      citationMeta.length > 0 && (
        <>
          <span>{lang === "zh" ? "，" : ", "}</span>
          <span>{citationMeta.join(lang === "zh" ? "，" : ", ")}</span>
        </>
      )
    }
    <span>{citationSuffix}</span>
  </p>
  {
    (abstractText || links.length > 0) && (
      <div class="publication__actions">
        {
          abstractText && (
            <button
              class="publication__abstract-toggle"
              type="button"
              aria-expanded="false"
              aria-controls={abstractId}
              data-abstract-toggle
            >
              {abstractLabel}
            </button>
          )
        }
        {
          links.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer">
              {link.label}
            </a>
          ))
        }
        {abstractText && <p id={abstractId} class="publication__abstract-text" hidden>{abstractText}</p>}
      </div>
    )
  }
</article>

<script is:inline>
  if (!window.__publicationAbstractToggleBound) {
    window.__publicationAbstractToggleBound = true;
    document.addEventListener("click", (event) => {
      const button = event.target.closest("[data-abstract-toggle]");
      if (!(button instanceof HTMLButtonElement)) return;

      const targetId = button.getAttribute("aria-controls");
      const target = targetId ? document.getElementById(targetId) : null;
      const expanded = button.getAttribute("aria-expanded") === "true";

      button.setAttribute("aria-expanded", String(!expanded));
      if (target) target.hidden = expanded;
    });
  }
</script>
