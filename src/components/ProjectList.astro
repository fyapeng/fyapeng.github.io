---
import {
  projectCategoryLabels,
  projectLinkLabels,
  projectStatusLabels,
  type Project
} from "../data/projects";
import type { Locale } from "../data/profile";

interface Props {
  projects: Project[];
  lang?: Locale;
  showCategory?: boolean;
}

const { projects, lang = "zh", showCategory = false } = Astro.props;
---

<div class="project-list">
  {
    projects.map((project) => (
      <article class="project-item">
        <div class="project-item__head">
          <h3>{project.name}</h3>
          <span class="project-status">{projectStatusLabels[project.status][lang]}</span>
        </div>
        {showCategory && <p class="eyebrow">{projectCategoryLabels[project.category][lang]}</p>}
        <p>{project.description[lang]}</p>
        <p class="tag-line">{project.tags[lang].join(" / ")}</p>
        <p class="text-links">
          {project.repoUrl && <a href={project.repoUrl} target="_blank" rel="noopener noreferrer">{projectLinkLabels.repo[lang]}</a>}
          {project.demoUrl && <a href={project.demoUrl} target="_blank" rel="noopener noreferrer">{projectLinkLabels.demo[lang]}</a>}
          {project.docsUrl && <a href={project.docsUrl} target="_blank" rel="noopener noreferrer">{projectLinkLabels.docs[lang]}</a>}
        </p>
      </article>
    ))
  }
</div>
