---
import { getCollection } from "astro:content";
import EmailLink from "../components/EmailLink.astro";
import { advisor, contactLinks, profile } from "../data/profile";
import { researchHighlights } from "../data/researchHighlights";
import { writingLinks } from "../data/writing";
import SiteLayout from "../layouts/SiteLayout.astro";

const latestEssay = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)[0];
const latestResearch = researchHighlights[0];
const essaySlug = latestEssay?.id.replace(/\.mdx?$/, "");
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
});
---

<SiteLayout lang="zh" active="home" title="首页" description={profile.zh.seoDescription}>
  <section class="profile-block">
    <div>
      <h1>{profile.zh.name}</h1>
      <p class="role">{profile.zh.role}</p>
      <p>专业方向为西方经济学，导师为中国社会科学院经济研究所<a href={advisor.url} target="_blank" rel="noopener noreferrer">{advisor.zh.name}</a>研究员，预计于 2029 年获得经济学博士学位。我的学术训练侧重应用微观经济学、经验研究设计与可复现研究工作流；研究兴趣、近期工作和简历信息见下方栏目。</p>
    </div>
    {
      profile.photo.src && (
        <img
          src={profile.photo.src}
          alt={profile.photo.alt.zh}
          width={profile.photo.width}
          height={profile.photo.height}
        />
      )
    }
  </section>

  <section class="contact-grid" aria-label="联系方式">
    {
      contactLinks.zh.map((link) =>
        "type" in link && link.type === "email" ? (
          <EmailLink label={link.label} icon={link.icon} />
        ) : (
          <a class="contact-card" href={link.href}>
            <span class="contact-icon" aria-hidden="true">{link.icon}</span>
            <span class="contact-copy">
              <span class="contact-label">{link.label}</span>
              <span class="contact-value">{link.value}</span>
            </span>
          </a>
        )
      )
    }
  </section>

  <section class="home-section">
    <header class="home-section__header">
      <span class="home-section__index">01</span>
      <div>
        <h2>研究兴趣</h2>
        <p>长期关注的问题意识与方法背景。</p>
      </div>
    </header>
    <div class="interest-block">
      <p class="interest-block__lead">研究领域为健康经济学、产业组织、微观理论与政策评估。</p>
      <p>
        当前研究主要围绕医疗服务市场中的支付规则、供需激励与政策后果展开，关注医保支付方式改革如何影响患者负担、医疗机构行为和资源配置效率。方法上结合微观计量、结构估计与政策反事实模拟，尝试识别医疗保险市场中的行为反应，并为医疗控费政策评估提供经验证据。
      </p>
      <div class="interest-tags" aria-label="研究领域">
        {profile.zh.researchFields.map((field) => <span>{field}</span>)}
      </div>
    </div>
  </section>

  <section class="home-section">
    <header class="home-section__header">
      <span class="home-section__index">02</span>
      <div>
        <h2>近期研究</h2>
        <p>选取一项最新工作及其中的特色图表。</p>
      </div>
    </header>
    {
      latestResearch && (
        <div class="feature-card">
          <a class="feature-card__figure" href={`/recent-research/#${latestResearch.slug}`} aria-label={latestResearch.title}>
            <img src={latestResearch.image} alt={latestResearch.imageAlt} loading="lazy" />
          </a>
          <div class="feature-card__body">
            <h3><a href={`/recent-research/#${latestResearch.slug}`}>{latestResearch.title}</a></h3>
            <p>{latestResearch.description}</p>
            <p class="text-links"><a href="/recent-research/">全部近期研究</a></p>
          </div>
        </div>
      )
    }
  </section>

  {
    latestEssay && (
      <section class="home-section">
        <header class="home-section__header">
          <span class="home-section__index">03</span>
          <div>
            <h2>随笔</h2>
            <p>近期写作与研究札记。</p>
          </div>
        </header>
        <article class="feature-card">
          {
            latestEssay.data.cover && (
              <a class="feature-card__figure" href={`/essays/${essaySlug}/`} aria-label={latestEssay.data.title}>
                <img src={latestEssay.data.cover} alt={latestEssay.data.coverAlt ?? ""} loading="lazy" />
              </a>
            )
          }
          <div class="feature-card__body">
            <p class="eyebrow">
              <time datetime={latestEssay.data.date.toISOString()}>{dateFormatter.format(latestEssay.data.date)}</time>
              <span>{latestEssay.data.category}</span>
            </p>
            <h3><a href={`/essays/${essaySlug}/`}>{latestEssay.data.title}</a></h3>
            <p>{latestEssay.data.summary}</p>
            <p class="text-links">
              <a href={`/essays/${essaySlug}/`}>阅读</a>
              <a href="/essays/">全部随笔</a>
            </p>
          </div>
        </article>
      </section>
    )
  }

  <nav class="bottom-writing-link" aria-label="其他文字">
    {
      writingLinks.map((item) => (
        <a class="quiet-link" href={item.url} target="_blank" rel="noopener noreferrer" data-new-tab>{item.displayTitle.zh}</a>
      ))
    }
  </nav>
</SiteLayout>
