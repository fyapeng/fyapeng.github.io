---
import { getCollection } from "astro:content";
import EssayList from "../components/EssayList.astro";
import ProjectList from "../components/ProjectList.astro";
import PublicationItem from "../components/PublicationItem.astro";
import { contactLinks, profile } from "../data/profile";
import { papers } from "../data/papers";
import { projects } from "../data/projects";
import SiteLayout from "../layouts/SiteLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
---

<SiteLayout lang="zh" active="home" title="首页" description={profile.zh.seoDescription}>
  <section class="profile-block">
    <div>
      <p class="eyebrow">{profile.identity.shortName}</p>
      <h1>{profile.zh.name}</h1>
      <p class="role">{profile.zh.role}</p>
      <p>{profile.zh.bio}</p>
      <p class="contact-links">
        {contactLinks.zh.map((link) => <a href={link.href}>{link.label}</a>)}
      </p>
    </div>
    <img src="/images/profile/bio.webp" alt="付亚鹏近照" width="180" height="180" />
  </section>

  <section class="section">
    <h2>研究兴趣</h2>
    <p>{profile.zh.researchFields.join("，")}</p>
  </section>

  <section class="section">
    <h2>代表性研究</h2>
    {papers.publications.map((paper) => <PublicationItem paper={paper} lang="zh" />)}
  </section>

  <section class="section">
    <h2>近期随笔</h2>
    <EssayList essays={essays} lang="zh" />
  </section>

  <section class="section">
    <h2>FyaLab</h2>
    <ProjectList projects={featuredProjects} />
  </section>
</SiteLayout>
