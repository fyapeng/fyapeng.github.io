---
import { getCollection } from "astro:content";
import EmailLink from "../components/EmailLink.astro";
import { contactLinks, profile } from "../data/profile";
import { researchHighlights } from "../data/researchHighlights";
import { writingLinks } from "../data/writing";
import SiteLayout from "../layouts/SiteLayout.astro";

const latestEssay = (await getCollection("essays", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)[0];
const latestResearch = researchHighlights[0];
const essaySlug = latestEssay?.id.replace(/\.mdx?$/, "");
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
});
---

<SiteLayout lang="zh" active="home" title="首页" description={profile.zh.seoDescription}>
  <section class="profile-block">
    <div>
      <h1>{profile.zh.name}</h1>
      <p class="role">{profile.zh.role}</p>
      <p>{profile.zh.bio}</p>
    </div>
    {
      profile.photo.src && (
        <img
          src={profile.photo.src}
          alt={profile.photo.alt.zh}
          width={profile.photo.width}
          height={profile.photo.height}
        />
      )
    }
  </section>

  <section class="contact-grid" aria-label="联系方式">
    {
      contactLinks.zh.map((link) =>
        "type" in link && link.type === "email" ? (
          <EmailLink label={link.label} icon={link.icon} />
        ) : (
          <a class="contact-card" href={link.href}>
            <span class="contact-icon" aria-hidden="true">{link.icon}</span>
            <span class="contact-copy">
              <span class="contact-label">{link.label}</span>
              <span class="contact-value">{link.value}</span>
            </span>
          </a>
        )
      )
    }
  </section>

  <section class="section section--compact">
    <h2>研究兴趣</h2>
    <p>{profile.zh.researchFields.join("，")}</p>
  </section>

  <section class="section section--compact">
    <h2>近期研究</h2>
    {
      latestResearch && (
        <div class="research-brief">
          <a class="research-brief__figure" href={`/research/#${latestResearch.slug}`} aria-label={latestResearch.title}>
            <img src={latestResearch.image} alt={latestResearch.imageAlt} loading="lazy" />
          </a>
          <div class="research-brief__body">
            <h3><a href={`/research/#${latestResearch.slug}`}>{latestResearch.title}</a></h3>
            <p>{latestResearch.description}</p>
            <p class="text-links"><a href="/research/#recent-research">全部近期研究</a></p>
          </div>
        </div>
      )
    }
  </section>

  {
    latestEssay && (
      <section class="section section--compact">
        <h2>随笔</h2>
        <article class="home-essay">
          <p class="eyebrow">
            <time datetime={latestEssay.data.date.toISOString()}>{dateFormatter.format(latestEssay.data.date)}</time>
            <span>{latestEssay.data.category}</span>
          </p>
          <h3><a href={`/essays/${essaySlug}/`}>{latestEssay.data.title}</a></h3>
          <p>{latestEssay.data.summary}</p>
          <p class="text-links">
            <a href={`/essays/${essaySlug}/`}>阅读</a>
            <a href="/essays/">全部随笔</a>
          </p>
        </article>
      </section>
    )
  }

  <section class="section section--quiet section--compact">
    <h2>文字</h2>
    <div class="writing-list">
      {
        writingLinks.map((item) => (
          <article class="writing-item">
            <p class="writing-item__meta">{item.displayTitle.zh}｜{item.type.zh}｜{item.length.zh}</p>
            <p>{item.description.zh}</p>
            <p class="text-links"><a href={item.url}>{item.linkText.zh}</a></p>
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>
