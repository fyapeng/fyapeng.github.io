---
import EmailLink from "../components/EmailLink.astro";
import ProjectList from "../components/ProjectList.astro";
import PublicationItem from "../components/PublicationItem.astro";
import { contactLinks, profile } from "../data/profile";
import { papers } from "../data/papers";
import { projectCategoryLabels, projects } from "../data/projects";
import { writingLinks } from "../data/writing";
import SiteLayout from "../layouts/SiteLayout.astro";

const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
const writingArchiveNote = writingLinks[0]?.archiveNote.zh;
---

<SiteLayout lang="zh" active="home" title="首页" description={profile.zh.seoDescription}>
  <section class="profile-block">
    <div>
      <h1>{profile.zh.name}</h1>
      <p class="role">{profile.zh.role}</p>
      <p>{profile.zh.bio}</p>
      <p class="contact-links">
        {
          contactLinks.zh.map((link) =>
            "type" in link && link.type === "email" ? (
              <EmailLink label={link.label} />
            ) : (
              <a href={link.href}>{link.label}</a>
            )
          )
        }
      </p>
    </div>
    {
      profile.photo.src && (
        <img
          src={profile.photo.src}
          alt={profile.photo.alt.zh}
          width={profile.photo.width}
          height={profile.photo.height}
        />
      )
    }
  </section>

  <section class="section">
    <h2>研究兴趣</h2>
    <p>{profile.zh.researchFields.join("，")}</p>
  </section>

  <section class="section">
    <h2>代表性研究</h2>
    {papers.publications.map((paper) => <PublicationItem paper={paper} lang="zh" />)}
  </section>

  <section class="section">
    <h2>FyaLab</h2>
    <p class="section-intro">FyaLab 是我整理研究工具、代码项目与小型实验的地方。这里展示的是精选项目，而不是完整 GitHub 仓库列表。</p>
    <div class="project-group">
      <h3 class="project-group__title">{projectCategoryLabels["research-workflow"].zh}</h3>
      <ProjectList projects={featuredProjects} lang="zh" />
    </div>
    <p class="text-links"><a href="/fyalab/">查看全部精选项目</a></p>
  </section>

  <section class="section section--quiet">
    <h2>文字</h2>
    <div class="writing-list">
      {
        writingLinks.map((item) => (
          <article class="writing-item">
            <p class="writing-item__meta">{item.displayTitle.zh}｜{item.type.zh}｜{item.length.zh}</p>
            <p>{item.description.zh}</p>
            <p class="text-links"><a href={item.url}>{item.linkText.zh}</a></p>
          </article>
        ))
      }
    </div>
    {writingArchiveNote && <p class="section-note">{writingArchiveNote}</p>}
  </section>
</SiteLayout>
