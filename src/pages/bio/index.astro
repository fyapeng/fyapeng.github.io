---
import EmailLink from "../../components/EmailLink.astro";
import { advisor, contactLinks, profile } from "../../data/profile";
import SiteLayout from "../../layouts/SiteLayout.astro";
---

<SiteLayout lang="en" active="bio" title="Bio" description={profile.en.seoDescription}>
  <section class="profile-block">
    <div>
      <h1>{profile.en.name}</h1>
      <p class="role">{profile.en.role}</p>
      <p set:html={profile.en.bio.replace(advisor.en.name, `<a href="${advisor.url}" target="_blank" rel="noopener noreferrer">${advisor.en.name}</a>`)} />
    </div>
    {
      profile.photo.src && (
        <img
          src={profile.photo.src}
          alt={profile.photo.alt.en}
          width={profile.photo.width}
          height={profile.photo.height}
        />
      )
    }
  </section>

  <section class="contact-grid" aria-label="Contact">
    {
      contactLinks.en.map((link) =>
        "type" in link && link.type === "email" ? (
          <EmailLink label={link.label} icon={link.icon} />
        ) : (
          <a class="contact-card" href={link.href}>
            <span class="contact-icon" aria-hidden="true">{link.icon}</span>
            <span class="contact-copy">
              <span class="contact-label">{link.label}</span>
              <span class="contact-value">{link.value}</span>
            </span>
          </a>
        )
      )
    }
  </section>
</SiteLayout>
