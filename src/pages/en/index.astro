---
import { getCollection } from "astro:content";
import EssayList from "../../components/EssayList.astro";
import ProjectList from "../../components/ProjectList.astro";
import PublicationItem from "../../components/PublicationItem.astro";
import { contactLinks, profile } from "../../data/profile";
import { papers } from "../../data/papers";
import { projects } from "../../data/projects";
import SiteLayout from "../../layouts/SiteLayout.astro";

const essays = (await getCollection("essays", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
---

<SiteLayout lang="en" active="home" title="Home" description={profile.en.seoDescription}>
  <section class="profile-block">
    <div>
      <p class="eyebrow">{profile.identity.shortName}</p>
      <h1>{profile.en.name}</h1>
      <p class="role">{profile.en.role}</p>
      <p>{profile.en.bio}</p>
      <p class="contact-links">
        {contactLinks.en.map((link) => <a href={link.href}>{link.label}</a>)}
      </p>
    </div>
    <img src="/images/profile/bio.webp" alt="Portrait of Yapeng Fu" width="180" height="180" />
  </section>

  <section class="section">
    <h2>Research Interests</h2>
    <p>{profile.en.researchFields.join(", ")}</p>
  </section>

  <section class="section">
    <h2>Selected Research</h2>
    {papers.publications.map((paper) => <PublicationItem paper={paper} lang="en" />)}
  </section>

  <section class="section">
    <h2>Recent Essays</h2>
    <EssayList essays={essays} lang="en" />
  </section>

  <section class="section">
    <h2>FyaLab</h2>
    <ProjectList projects={featuredProjects} />
  </section>
</SiteLayout>
