---
import ProjectList from "../../../components/ProjectList.astro";
import { projectCategoryLabels, projects } from "../../../data/projects";
import SiteLayout from "../../../layouts/SiteLayout.astro";

const researchProjects = projects.filter((project) => project.category === "research-workflow");
const experimentProjects = projects.filter((project) => project.category === "experiments");
---

<SiteLayout lang="en" active="fyalab" title="FyaLab">
  <header class="page-header section--reading">
    <h1>FyaLab</h1>
    <p>FyaLab is where I organize selected research tools, code projects, and small experiments. It is curated manually rather than mirrored from every GitHub repository.</p>
  </header>
  <section class="section--reading">
    <h2>{projectCategoryLabels["research-workflow"].en}</h2>
    <ProjectList projects={researchProjects} lang="en" />
  </section>
  <section class="section section--reading">
    <h2>{projectCategoryLabels.experiments.en}</h2>
    <ProjectList projects={experimentProjects} lang="en" />
  </section>
</SiteLayout>
