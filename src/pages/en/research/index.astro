---
import ProjectList from "../../../components/ProjectList.astro";
import PublicationItem from "../../../components/PublicationItem.astro";
import { papers } from "../../../data/papers";
import { projects } from "../../../data/projects";
import SiteLayout from "../../../layouts/SiteLayout.astro";

const linkedProjects = projects.filter((project) => project.category === "Research / Workflow");
---

<SiteLayout lang="en" active="research" title="Research">
  <header class="page-header section--reading">
    <h1>Research</h1>
    <p>Research interests include health economics, public economics, medical payment reform, and applied microeconometrics.</p>
  </header>

  <section class="section section--reading">
    <h2>Publications</h2>
    {papers.publications.map((paper) => <PublicationItem paper={paper} lang="en" />)}
  </section>

  {
    papers.workingPapers.length > 0 && (
      <section class="section section--reading">
        <h2>Working Papers</h2>
        {papers.workingPapers.map((paper) => <PublicationItem paper={paper} lang="en" />)}
      </section>
    )
  }

  {
    linkedProjects.length > 0 && (
      <section class="section section--reading">
        <h2>Code and Data</h2>
        <ProjectList projects={linkedProjects} lang="en" />
      </section>
    )
  }
</SiteLayout>
