---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const essays = await getCollection("essays", ({ data }) => !data.draft);
  return essays.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
});
---

<SiteLayout lang="zh" active="essays" title={entry.data.title} description={entry.data.summary}>
  <article class="essay-article">
    <header>
      <p class="eyebrow">
        <time datetime={entry.data.date.toISOString()}>{dateFormatter.format(entry.data.date)}</time>
        <span>{entry.data.category}</span>
      </p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.summary}</p>
      <p class="tag-line">{entry.data.tags.join(" / ")}</p>
      {
        entry.data.cover && (
          <figure class="cover">
            <img src={entry.data.cover} alt={entry.data.coverAlt ?? ""} />
          </figure>
        )
      }
      {
        entry.data.wechatUrl && (
          <p class="text-links"><a href={entry.data.wechatUrl} target="_blank" rel="noopener noreferrer">公众号原文</a></p>
        )
      }
    </header>
    <div class="content">
      <Content />
    </div>
  </article>
</SiteLayout>
