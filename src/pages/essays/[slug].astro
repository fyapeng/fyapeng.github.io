---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import { estimateReadingMinutes } from "../../utils/readingTime";

export async function getStaticPaths() {
  const essays = await getCollection("essays", ({ data }) => !data.draft);
  return essays.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit"
});
const slug = entry.id.replace(/\.mdx?$/, "");
const canonicalPath = `/essays/${slug}/`;
const readingMinutes = estimateReadingMinutes(entry.body ?? "");
const publishedTime = entry.data.date.toISOString();
const modifiedTime = entry.data.updatedAt?.toISOString();
---

<SiteLayout
  lang="zh"
  active="essays"
  title={entry.data.title}
  description={entry.data.summary}
  canonicalPath={canonicalPath}
  image={entry.data.cover}
  imageAlt={entry.data.coverAlt}
  pageType="article"
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  keywords={entry.data.tags}
>
  <article class="essay-article">
    <header>
      <p class="eyebrow">
        <time datetime={publishedTime}>{dateFormatter.format(entry.data.date)}</time>
        <span>{entry.data.category}</span>
        <span>约 {readingMinutes} 分钟阅读</span>
      </p>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.summary}</p>
      <p class="tag-line">{entry.data.tags.join(" / ")}</p>
      {
        entry.data.updatedAt && (
          <p class="section-note">
            最后修订于 <time datetime={modifiedTime}>{dateFormatter.format(entry.data.updatedAt)}</time>
          </p>
        )
      }
      {
        entry.data.cover && (
          <figure class="cover">
            <img src={entry.data.cover} alt={entry.data.coverAlt ?? ""} />
            {
              (entry.data.coverCaption || entry.data.coverCredit) && (
                <figcaption>
                  {entry.data.coverCaption}
                  {entry.data.coverCaption && entry.data.coverCredit && <span aria-hidden="true"> · </span>}
                  {
                    entry.data.coverCredit && entry.data.coverCreditUrl ? (
                      <a href={entry.data.coverCreditUrl}>{entry.data.coverCredit}</a>
                    ) : (
                      entry.data.coverCredit
                    )
                  }
                </figcaption>
              )
            }
          </figure>
        )
      }
      {
        entry.data.wechatUrl && (
          <p class="text-links"><a href={entry.data.wechatUrl} target="_blank" rel="noopener noreferrer">公众号原文</a></p>
        )
      }
    </header>
    <div class="content">
      <Content />
    </div>
  </article>
</SiteLayout>
